# ==============================================
# CONFIGURACIÓN DEL BACKEND - SIAONDA V2
# ==============================================

# ---------------------------------------------
# Base de Datos
# ---------------------------------------------
DATABASE_URL="postgresql://usuario:password@localhost:5432/siaonda_v2"

# ---------------------------------------------
# Servidor
# ---------------------------------------------
PORT=3000
NODE_ENV=development

# ---------------------------------------------
# Autenticación JWT
# ---------------------------------------------
# IMPORTANTE: Cambiar estos valores en producción
JWT_SECRET=tu_secreto_super_seguro_cambiar_en_produccion
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=tu_secreto_refresh_super_seguro
JWT_REFRESH_EXPIRES_IN=7d

# ---------------------------------------------
# CORS - Configuración del frontend
# ---------------------------------------------
CORS_ORIGIN=http://localhost:5173

# ---------------------------------------------
# Email (Nodemailer)
# ---------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_password_de_aplicacion
EMAIL_FROM="SIAONDA <noreply@onda.gob.do>"

# ---------------------------------------------
# Gestión de Archivos
# ---------------------------------------------
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# ---------------------------------------------
# Paginación
# ---------------------------------------------
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ---------------------------------------------
# NCF (Comprobantes Fiscales República Dominicana)
# ---------------------------------------------
NCF_ENABLED=true
NCF_RNC_ONDA=tu_rnc_aqui
